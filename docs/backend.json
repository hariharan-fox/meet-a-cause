{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's public and private profile data.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The user's unique ID."
        },
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "enum": ["volunteer"],
          "description": "The user's role in the application."
        },
        "avatarUrl": {
          "type": "string",
          "format": "uri",
          "description": "URL for the user's avatar image."
        },
        "phoneNumber": {
            "type": "string",
            "description": "The user's phone number."
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" },
          "description": "A list of the user's skills."
        },
        "interests": {
          "type": "array",
          "items": { "type": "string" },
          "description": "A list of the user's interests."
        },
        "completedEventIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of event IDs the user has completed."
        },
        "registeredEventIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of event IDs the user is registered for."
        },
        "earnedBadgeIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of badge IDs the user has earned."
        },
        "loggedHours": {
          "type": "number",
          "description": "Total number of hours volunteered."
        },
        "notifications": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "createdAt": { "type": "string" },
              "isRead": { "type": "boolean" }
            },
            "required": ["id", "title", "description", "createdAt", "isRead"]
          }
        }
      },
      "required": ["id", "name", "email", "role", "completedEventIds", "registeredEventIds", "earnedBadgeIds", "loggedHours", "notifications"]
    }
  },
  "auth": {
    "providers": ["phone", "emailPassword"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores the profile information for each user."
    }
  }
}
