rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check ownership
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    match /users/{userId} {
      // A user can create their own profile, but we must validate the initial data
      // to ensure it's safe and consistent.
      allow create: if isOwner(userId)
                    && request.resource.data.id == userId
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 1
                    && request.resource.data.role == 'volunteer'
                    && request.resource.data.avatarUrl is string
                    && request.resource.data.skills is list && request.resource.data.skills.size() == 0
                    && request.resource.data.interests is list && request.resource.data.interests.size() == 0
                    && request.resource.data.loggedHours == 0
                    && request.resource.data.completedEventIds is list && request.resource.data.completedEventIds.size() == 0
                    && request.resource.data.registeredEventIds is list && request.resource.data.registeredEventIds.size() == 0
                    && request.resource.data.earnedBadgeIds is list && request.resource.data.earnedBadgeIds.size() == 0
                    && request.resource.data.notifications is list && request.resource.data.notifications.size() == 1;

      // A logged-in user can read and update their own profile.
      allow read, update: if isOwner(userId);
      
      // Deleting user profiles from the client is disabled for security.
      allow delete: if false;
    }
  }
}
